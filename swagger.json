{
  "openapi": "3.0.0",
  "info": {
    "title": "API do Desafio Final de backend do PD Itabira (Híbrida)",
    "description": "Gestão de Alunos, Cursos e Matrículas. Identificação flexível e controle de status.",
    "version": "1.4.0"
  },
  "servers": [
    {
      "url": "https://desafiofinal-tanh.onrender.com",
      "description": "Servidor de Produção (Render)"
    },
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "schemas": {
      "ErroPadrao": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "statusCode": { "type": "integer" }
        }
      },
      "Aluno": {
        "type": "object",
        "properties": {
          "codigo_aluno": { "type": "integer" },
          "nome": { "type": "string" },
          "email": { "type": "string" }
        }
      },
      "AlunoInput": {
        "type": "object",
        "required": ["nome", "email"],
        "properties": {
          "nome": { "type": "string", "example": "João Silva" },
          "email": { "type": "string", "example": "joao@email.com" }
        }
      },
      "Curso": {
        "type": "object",
        "properties": {
          "codigo_curso": { "type": "integer" },
          "nome_curso": { "type": "string" },
          "carga_horaria": { "type": "integer" }
        }
      },
      "CursoInput": {
        "type": "object",
        "required": ["nome_curso"],
        "properties": {
          "nome_curso": { "type": "string", "example": "Backend Node.js" },
          "carga_horaria": { "type": "integer", "example": 40 }
        }
      },
      "Matricula": {
        "type": "object",
        "properties": {
          "codigo_matricula": { "type": "integer" },
          "nome_aluno": { "type": "string" },
          "codigo_aluno": { "type": "integer" },
          "nome_curso": { "type": "string" },
          "codigo_curso": { "type": "integer" },
          "status": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/alunos": {
      "get": {
        "tags": ["Alunos"],
        "summary": "Lista todos os alunos",
        "responses": {
          "200": {
            "description": "Sucesso",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Aluno" } } } }
          }
        }
      },
      "post": {
        "tags": ["Alunos"],
        "summary": "Cadastra um novo aluno",
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AlunoInput" } } }
        },
        "responses": {
          "201": { 
            "description": "Criado",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Aluno" } } } 
          }
        }
      }
    },
    "/alunos/{identificador}": {
      "put": {
        "tags": ["Alunos"],
        "summary": "Atualiza aluno (Identifica por Código, Nome ou E-mail)",
        "parameters": [
          { "name": "identificador", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/AlunoInput" } } }
        },
        "responses": { "200": { "description": "Atualizado com sucesso" } }
      },
      "delete": {
        "tags": ["Alunos"],
        "summary": "Remove aluno e mostra quem foi deletado",
        "parameters": [
          { "name": "identificador", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { 
          "200": { 
            "description": "Aluno removido",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensagem": { "type": "string" },
                    "alunoRemovido": { "$ref": "#/components/schemas/Aluno" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/cursos": {
      "get": {
        "tags": ["Cursos"],
        "summary": "Lista todos os cursos",
        "responses": {
          "200": {
            "description": "Sucesso",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Curso" } } } }
          }
        }
      },
      "post": {
        "tags": ["Cursos"],
        "summary": "Cria um novo curso",
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CursoInput" } } }
        },
        "responses": { "201": { "description": "Criado" } }
      }
    },
    "/matriculas": {
      "get": {
        "tags": ["Matrículas"],
        "summary": "Lista todas as matrículas realizadas",
        "responses": {
          "200": {
            "description": "Sucesso",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Matricula" } } } }
          }
        }
      },
      "post": {
        "tags": ["Matrículas"],
        "summary": "Matricular um aluno",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "codigo_aluno": { "type": "integer" },
                  "codigo_curso": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Matrícula realizada" } }
      }
    },
    "/matriculas/aluno/{codigo_aluno}": {
      "get": {
        "tags": ["Matrículas"],
        "summary": "Listar cursos de um aluno específico",
        "parameters": [
          { "name": "codigo_aluno", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Lista de cursos do aluno",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Curso" } } } }
          }
        }
      }
    },
    "/matriculas/{codigo}/status": {
      "patch": {
        "tags": ["Matrículas"],
        "summary": "Alterar status da matrícula",
        "parameters": [
          { "name": "codigo", "in": "path", "required": true, "description": "Código da matrícula", "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string", "enum": ["ativa", "cancelada", "concluida", "suspensa"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Status atualizado com sucesso" }
        }
      }
    }
  }
}