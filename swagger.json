{
  "openapi": "3.0.0",
  "info": {
    "title": "API do Desafio Final de backend do PD Itabira (Protegida)",
    "description": "Gestão de Alunos, Cursos e Matrículas usando Identificadores Amigáveis. UUIDs ocultos por segurança.",
    "version": "1.2.0"
  },
  "servers": [
    {
      "url": "https://desafiofinal-tanh.onrender.com",
      "description": "Servidor de Produção (Render)"
    },
    {
      "url": "http://localhost:3000",
      "description": "Servidor Local"
    }
  ],
  "components": {
    "schemas": {
      "ErroPadrao": {
        "type": "object",
        "properties": {
          "error": { "type": "string" },
          "statusCode": { "type": "integer" }
        }
      },
      "Aluno": {
        "type": "object",
        "properties": {
          "codigo_aluno": { "type": "integer" },
          "nome": { "type": "string" },
          "email": { "type": "string" }
        }
      },
      "Curso": {
        "type": "object",
        "properties": {
          "codigo_curso": { "type": "integer" },
          "nome_curso": { "type": "string" },
          "carga_horaria": { "type": "integer" }
        }
      },
      "Matricula": {
        "type": "object",
        "properties": {
          "codigo_matricula": { "type": "integer" },
          "nome_aluno": { "type": "string" },
          "nome_curso": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  },
  "paths": {
    "/alunos": {
      "get": {
        "tags": ["Alunos"],
        "summary": "Lista alunos (filtra por nome ou código amigável)",
        "parameters": [
          { "name": "nome", "in": "query", "schema": { "type": "string" } },
          { "name": "codigo_aluno", "in": "query", "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": {
            "description": "Sucesso",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Aluno" } } } }
          }
        }
      },
      "post": {
        "tags": ["Alunos"],
        "summary": "Cadastra um novo aluno",
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Aluno" } } }
        },
        "responses": {
          "201": { "description": "Aluno criado", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Aluno" } } } }
        }
      }
    },
    "/alunos/{codigo}": {
      "get": {
        "tags": ["Alunos"],
        "summary": "Busca aluno pelo código amigável",
        "parameters": [{ "name": "codigo", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Sucesso", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Aluno" } } } }
        }
      },
      "put": {
        "tags": ["Alunos"],
        "summary": "Atualiza aluno pelo código",
        "parameters": [{ "name": "codigo", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Aluno" } } }
        },
        "responses": { "200": { "description": "Atualizado" } }
      },
      "delete": {
        "tags": ["Alunos"],
        "summary": "Remove aluno pelo código",
        "parameters": [{ "name": "codigo", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "204": { "description": "Removido" } }
      }
    },
    "/cursos": {
      "get": {
        "tags": ["Cursos"],
        "summary": "Lista cursos",
        "responses": {
          "200": { "description": "Sucesso", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Curso" } } } } }
        }
      },
      "post": {
        "tags": ["Cursos"],
        "summary": "Cria um curso",
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Curso" } } }
        },
        "responses": { "201": { "description": "Criado" } }
      }
    },
    "/matriculas": {
      "get": {
        "tags": ["Matrículas"],
        "summary": "Lista todas as matrículas",
        "responses": {
          "200": { "description": "Sucesso", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Matricula" } } } } }
        }
      },
      "post": {
        "tags": ["Matrículas"],
        "summary": "Matricular aluno",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "codigo_aluno": { "type": "integer" },
                  "codigo_curso": { "type": "integer" }
                }
              }
            }
          }
        },
        "responses": { "201": { "description": "Matriculado" } }
      }
    }
  }
}